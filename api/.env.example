SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=3001

# Native desktop recorder: HS256 secret for short-lived upload/deep-link JWTs.
# Generate: openssl rand -base64 48
# Railway / Render: add as a variable (never commit the real value to git).
RECORDING_JWT_SECRET=
# Optional override (default 120)
RECORDING_JWT_TTL_SEC=120

# Public API origin for deep links (no trailing slash). Must match what the dashboard uses as VITE_API_URL.
# Local: http://localhost:3001
# Railway: https://your-api.up.railway.app (same URL you set in VITE_API_URL on Vercel/Railway dashboard)
PUBLIC_API_URL=

# Desktop release metadata (authenticated GET /api/desktop/releases/latest?platform=darwin|win32)
DESKTOP_MAC_VERSION=0.1.0
DESKTOP_MAC_DOWNLOAD_URL=
DESKTOP_MAC_FILENAME=ProductPulseRecorder.dmg
DESKTOP_WIN_VERSION=0.1.0
DESKTOP_WIN_DOWNLOAD_URL=
DESKTOP_WIN_FILENAME=ProductPulseRecorderSetup.exe