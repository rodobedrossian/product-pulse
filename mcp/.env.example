# ─── Supabase credentials ────────────────────────────────────────────────────
# Use the same project as your api/ service
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Transport mode ───────────────────────────────────────────────────────────
# 'stdio'  → local use (Claude Desktop, Cursor, Windsurf)
# 'http'   → Railway deployment (remote access)
MCP_TRANSPORT=stdio

# ─── stdio mode only ──────────────────────────────────────────────────────────
# Your Supabase JWT — get it from the dashboard:
#   1. Open https://product-pulse-kappa.vercel.app in Chrome
#   2. DevTools → Application → Local Storage → your Supabase key
#   3. Find access_token, paste it here
#
# ⚠️  This token expires in ~1 hour. For persistent access, use HTTP mode.
SUPABASE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── HTTP mode only ───────────────────────────────────────────────────────────
# PORT is injected automatically by Railway — no need to set it manually
# PORT=3002
