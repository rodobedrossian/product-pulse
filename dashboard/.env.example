# API base: must include the scheme. If you omit https://, the browser treats the value as a path on your
# frontend domain (broken requests + 404 on Vercel).
# Local: http://localhost:3001 OR leave empty to use Vite /api proxy.
# Production: https://your-service.up.railway.app (no trailing slash)
VITE_API_URL=http://localhost:3001

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public dashboard origin (invite links, /join/…). Include https:// in production (e.g. https://….vercel.app).
VITE_APP_URL=http://localhost:5173
